# X API (optional, 00/mo Basic tier)
X_BEARER_TOKEN=your-bearer-token

# Pipeline config
PUBLISH_THRESHOLD=65
POLL_INTERVAL_SECONDS=90
SCORE_BATCH_SIZE=50
AFINN_CONTROVERSY_THRESHOLD=50
